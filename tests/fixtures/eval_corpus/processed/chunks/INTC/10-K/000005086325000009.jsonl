{"schema_version":"chunk_record.v1","chunk_id":"sec_0000050863_000005086325000009_s07_c0008","document_id":"sec_0000050863_000005086325000009","company_name":"Intel Corporation","ticker":"INTC","cik":"0000050863","form_type":"10-K","filing_date":"2025-01-31","report_date":"2024-12-28","accession_number":"0000050863-25-000009","source_url":"https://www.sec.gov/Archives/edgar/data/50863/000005086325000009/intc-20241228.htm","filing_index_url":"https://www.sec.gov/Archives/edgar/data/50863/000005086325000009/","source_kind":"primary_document","raw_path":"data/raw/filings/INTC/10-K/000005086325000009/intc-20241228.htm","section_key":"md_and_a","section_title":"Management's Discussion and Analysis of Financial Condition and Results of Operations","section_order":7,"item_number":"7","parser_strategy":"item_headers","chunk_index":8,"char_start":0,"char_end":247,"token_start":0,"token_end":39,"token_count":39,"content_hash":"cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc","text":"Intel Foundry revenue was $17.0 billion in fiscal year 2024, and operating loss was $11.6 billion. Intel said the segment remained in investment mode as it ramped process technology, factory utilization, and external foundry programs."}
