{"schema_version":"chunk_record.v1","chunk_id":"sec_0000002488_000000248826000018_s02_c0004","document_id":"sec_0000002488_000000248826000018","company_name":"Advanced Micro Devices, Inc.","ticker":"AMD","cik":"0000002488","form_type":"10-K","filing_date":"2026-02-04","report_date":"2025-12-27","accession_number":"0000002488-26-000018","source_url":"https://www.sec.gov/Archives/edgar/data/2488/000000248826000018/amd-20251227.htm","filing_index_url":"https://www.sec.gov/Archives/edgar/data/2488/000000248826000018/","source_kind":"primary_document","raw_path":"data/raw/filings/AMD/10-K/000000248826000018/amd-20251227.htm","section_key":"business","section_title":"Business","section_order":2,"item_number":"1","parser_strategy":"item_headers","chunk_index":4,"char_start":0,"char_end":286,"token_start":0,"token_end":44,"token_count":44,"content_hash":"5555555555555555555555555555555555555555555555555555555555555555","text":"AMD said data center growth was supported by EPYC server CPUs and Instinct accelerators, including MI300 products, as cloud and enterprise customers expanded AI deployments. The company highlighted both CPU and GPU demand in its data center business."}
{"schema_version":"chunk_record.v1","chunk_id":"sec_0000002488_000000248826000018_s07_c0006","document_id":"sec_0000002488_000000248826000018","company_name":"Advanced Micro Devices, Inc.","ticker":"AMD","cik":"0000002488","form_type":"10-K","filing_date":"2026-02-04","report_date":"2025-12-27","accession_number":"0000002488-26-000018","source_url":"https://www.sec.gov/Archives/edgar/data/2488/000000248826000018/amd-20251227.htm","filing_index_url":"https://www.sec.gov/Archives/edgar/data/2488/000000248826000018/","source_kind":"primary_document","raw_path":"data/raw/filings/AMD/10-K/000000248826000018/amd-20251227.htm","section_key":"md_and_a","section_title":"Management's Discussion and Analysis of Financial Condition and Results of Operations","section_order":7,"item_number":"7","parser_strategy":"item_headers","chunk_index":6,"char_start":0,"char_end":280,"token_start":0,"token_end":44,"token_count":44,"content_hash":"6666666666666666666666666666666666666666666666666666666666666666","text":"Data Center segment revenue increased to $12.6 billion in fiscal year 2025 from $6.5 billion in the prior year. AMD attributed the increase to higher sales of EPYC processors and Instinct GPU products for cloud, enterprise, and AI workloads."}
