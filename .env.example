# Copy this file to .env when local configuration is needed.

# Descriptive SEC user agent. Replace with your own name and contact.
SEC_USER_AGENT="Your Name your.email@example.com"

# Local environment flags
SEC_COPILOT_ENV="development"
SEC_COPILOT_LOG_LEVEL="INFO"
SEC_COPILOT_PROJECT_ROOT=""

# Optional Hugging Face Hub token for gated or private model downloads.
HF_TOKEN=""

# Runtime storage locations. Container deployments should mount these paths as volumes.
SEC_COPILOT_DATA_DIR="./data"
SEC_COPILOT_CHROMA_DIR="./artifacts/chroma"
SEC_COPILOT_COMPANIES_CONFIG_PATH="./configs/companies.yaml"
SEC_COPILOT_REFRESH_FORM_TYPES="10-K,10-Q"
SEC_COPILOT_REFRESH_ANNUAL_LIMIT="2"
SEC_COPILOT_REFRESH_QUARTERLY_LIMIT="4"

# Optional runtime cache locations. Container deployments can point these at writable ephemeral paths.
HF_HOME=""
TRANSFORMERS_CACHE=""
SENTENCE_TRANSFORMERS_HOME=""

# Optional live LLM provider for grounded answer generation.
# Unit tests do not require this.
# Live answer generation requires outbound network access.
OPENAI_API_KEY=""
SEC_COPILOT_OPENAI_MODEL="gpt-4.1-mini"

# Optional Streamlit frontend request timeouts in seconds.
SEC_COPILOT_UI_BACKEND_URL="http://127.0.0.1:8000"
SEC_COPILOT_UI_STATUS_TIMEOUT_SECONDS="10"
SEC_COPILOT_UI_QUERY_TIMEOUT_SECONDS="180"
SEC_COPILOT_UI_RETRIEVE_DEBUG_TIMEOUT_SECONDS="180"
SEC_COPILOT_UI_INGEST_TIMEOUT_SECONDS="900"
