{"schema_version":"chunk_record.v1","chunk_id":"sec_0001045810_000104581025000023_s02_c0005","document_id":"sec_0001045810_000104581025000023","company_name":"NVIDIA","ticker":"NVDA","cik":"0001045810","form_type":"10-K","filing_date":"2025-02-26","report_date":"2025-01-26","accession_number":"0001045810-25-000023","source_url":"https://www.sec.gov/Archives/edgar/data/1045810/000104581025000023/nvda-20250126.htm","filing_index_url":"https://www.sec.gov/Archives/edgar/data/1045810/000104581025000023/","source_kind":"primary_document","raw_path":"data/raw/filings/NVDA/10-K/000104581025000023/nvda-20250126.htm","section_key":"risk_factors","section_title":"Risk Factors","section_order":2,"item_number":"1A","parser_strategy":"item_headers","chunk_index":5,"char_start":0,"char_end":276,"token_start":0,"token_end":44,"token_count":44,"content_hash":"3333333333333333333333333333333333333333333333333333333333333333","text":"Export controls, license requirements, and product transition rules affecting China and other markets may limit the customers that can buy certain NVIDIA products. The company said changes in these restrictions can reduce demand and require modifications to the product roadmap."}
