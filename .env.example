# Copy this file to .env when local configuration is needed.

# Descriptive SEC user agent. Replace with your own name and contact.
SEC_USER_AGENT="Your Name your.email@example.com"

# Local environment flags
SEC_COPILOT_ENV="development"
SEC_COPILOT_LOG_LEVEL="INFO"

# Future storage locations
SEC_COPILOT_DATA_DIR="./data"
SEC_COPILOT_CHROMA_DIR="./artifacts/chroma"

# Optional live LLM provider for grounded answer generation.
# Unit tests do not require this.
# Live answer generation requires outbound network access.
OPENAI_API_KEY=""
SEC_COPILOT_OPENAI_MODEL="gpt-4.1-mini"
