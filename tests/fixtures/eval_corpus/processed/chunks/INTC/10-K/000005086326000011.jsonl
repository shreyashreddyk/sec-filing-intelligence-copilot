{"schema_version":"chunk_record.v1","chunk_id":"sec_0000050863_000005086326000011_s02_c0005","document_id":"sec_0000050863_000005086326000011","company_name":"Intel Corporation","ticker":"INTC","cik":"0000050863","form_type":"10-K","filing_date":"2026-01-23","report_date":"2025-12-27","accession_number":"0000050863-26-000011","source_url":"https://www.sec.gov/Archives/edgar/data/50863/000005086326000011/intc-20251227.htm","filing_index_url":"https://www.sec.gov/Archives/edgar/data/50863/000005086326000011/","source_kind":"primary_document","raw_path":"data/raw/filings/INTC/10-K/000005086326000011/intc-20251227.htm","section_key":"business","section_title":"Business","section_order":2,"item_number":"1","parser_strategy":"item_headers","chunk_index":5,"char_start":0,"char_end":270,"token_start":0,"token_end":42,"token_count":42,"content_hash":"9999999999999999999999999999999999999999999999999999999999999999","text":"Intel highlighted Xeon processors, Gaudi AI accelerators, and AI PC products as part of its AI compute strategy. The company positioned these products as part of a broader effort to serve enterprise, cloud, and edge AI workloads."}
{"schema_version":"chunk_record.v1","chunk_id":"sec_0000050863_000005086326000011_s07_c0009","document_id":"sec_0000050863_000005086326000011","company_name":"Intel Corporation","ticker":"INTC","cik":"0000050863","form_type":"10-K","filing_date":"2026-01-23","report_date":"2025-12-27","accession_number":"0000050863-26-000011","source_url":"https://www.sec.gov/Archives/edgar/data/50863/000005086326000011/intc-20251227.htm","filing_index_url":"https://www.sec.gov/Archives/edgar/data/50863/000005086326000011/","source_kind":"primary_document","raw_path":"data/raw/filings/INTC/10-K/000005086326000011/intc-20251227.htm","section_key":"md_and_a","section_title":"Management's Discussion and Analysis of Financial Condition and Results of Operations","section_order":7,"item_number":"7","parser_strategy":"item_headers","chunk_index":9,"char_start":0,"char_end":269,"token_start":0,"token_end":43,"token_count":43,"content_hash":"aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa","text":"Intel Foundry revenue was $17.5 billion in fiscal year 2025, and operating loss widened to $13.4 billion. Intel said the segment continued to absorb spending tied to process technology execution, fab construction, and foundry customer ramps."}
{"schema_version":"chunk_record.v1","chunk_id":"sec_0000050863_000005086326000011_s02_c0006","document_id":"sec_0000050863_000005086326000011","company_name":"Intel Corporation","ticker":"INTC","cik":"0000050863","form_type":"10-K","filing_date":"2026-01-23","report_date":"2025-12-27","accession_number":"0000050863-26-000011","source_url":"https://www.sec.gov/Archives/edgar/data/50863/000005086326000011/intc-20251227.htm","filing_index_url":"https://www.sec.gov/Archives/edgar/data/50863/000005086326000011/","source_kind":"primary_document","raw_path":"data/raw/filings/INTC/10-K/000005086326000011/intc-20251227.htm","section_key":"business","section_title":"Business","section_order":2,"item_number":"1","parser_strategy":"item_headers","chunk_index":6,"char_start":0,"char_end":231,"token_start":0,"token_end":35,"token_count":35,"content_hash":"9d9d9d9d9d9d9d9d9d9d9d9d9d9d9d9d9d9d9d9d9d9d9d9d9d9d9d9d9d9d9d9d","text":"Intel said progress in Intel Foundry requires sustained investment in process technology, factory buildouts, and customer ramps. The company described foundry execution and manufacturing scale as central to its long-term strategy."}
