{"schema_version":"chunk_record.v1","chunk_id":"sec_0000002488_000000248825000012_s02_c0003","document_id":"sec_0000002488_000000248825000012","company_name":"Advanced Micro Devices, Inc.","ticker":"AMD","cik":"0000002488","form_type":"10-K","filing_date":"2025-02-05","report_date":"2024-12-28","accession_number":"0000002488-25-000012","source_url":"https://www.sec.gov/Archives/edgar/data/2488/000000248825000012/amd-20241228.htm","filing_index_url":"https://www.sec.gov/Archives/edgar/data/2488/000000248825000012/","source_kind":"primary_document","raw_path":"data/raw/filings/AMD/10-K/000000248825000012/amd-20241228.htm","section_key":"business","section_title":"Business","section_order":2,"item_number":"1","parser_strategy":"item_headers","chunk_index":3,"char_start":0,"char_end":268,"token_start":0,"token_end":41,"token_count":41,"content_hash":"7777777777777777777777777777777777777777777777777777777777777777","text":"AMD described itself as a fabless semiconductor company. It said it relies on third-party wafer foundries, especially TSMC, and on external assembly, test, and logistics partners rather than operating its own leading-edge manufacturing network."}
{"schema_version":"chunk_record.v1","chunk_id":"sec_0000002488_000000248825000012_s07_c0007","document_id":"sec_0000002488_000000248825000012","company_name":"Advanced Micro Devices, Inc.","ticker":"AMD","cik":"0000002488","form_type":"10-K","filing_date":"2025-02-05","report_date":"2024-12-28","accession_number":"0000002488-25-000012","source_url":"https://www.sec.gov/Archives/edgar/data/2488/000000248825000012/amd-20241228.htm","filing_index_url":"https://www.sec.gov/Archives/edgar/data/2488/000000248825000012/","source_kind":"primary_document","raw_path":"data/raw/filings/AMD/10-K/000000248825000012/amd-20241228.htm","section_key":"md_and_a","section_title":"Management's Discussion and Analysis of Financial Condition and Results of Operations","section_order":7,"item_number":"7","parser_strategy":"item_headers","chunk_index":7,"char_start":0,"char_end":250,"token_start":0,"token_end":40,"token_count":40,"content_hash":"8888888888888888888888888888888888888888888888888888888888888888","text":"Data Center segment revenue was $6.5 billion in fiscal year 2024. AMD said the business benefited from Genoa server CPU adoption and growing customer interest in Instinct accelerator products for AI and HPC workloads."}
{"schema_version":"chunk_record.v1","chunk_id":"sec_0000002488_000000248825000012_s10_c0006","document_id":"sec_0000002488_000000248825000012","company_name":"Advanced Micro Devices, Inc.","ticker":"AMD","cik":"0000002488","form_type":"10-K","filing_date":"2025-02-05","report_date":"2024-12-28","accession_number":"0000002488-25-000012","source_url":"https://www.sec.gov/Archives/edgar/data/2488/000000248825000012/amd-20241228.htm","filing_index_url":"https://www.sec.gov/Archives/edgar/data/2488/000000248825000012/","source_kind":"primary_document","raw_path":"data/raw/filings/AMD/10-K/000000248825000012/amd-20241228.htm","section_key":"risk_factors","section_title":"Risk Factors","section_order":10,"item_number":"1A","parser_strategy":"item_headers","chunk_index":6,"char_start":0,"char_end":247,"token_start":0,"token_end":39,"token_count":39,"content_hash":"7d7d7d7d7d7d7d7d7d7d7d7d7d7d7d7d7d7d7d7d7d7d7d7d7d7d7d7d7d7d7d7d","text":"AMD said its fabless model makes it dependent on third-party suppliers for wafers, packaging, assembly, and logistics. Disruptions at key foundry or backend manufacturing partners could affect product availability and margins."}
